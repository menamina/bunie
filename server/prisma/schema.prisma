generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String

  profile Profile[]
  
  inventory Inventory[]
  decluttered Decluttered []
  fullPan FullPan[]

  followers FollowRelation[] @relation("userFollowers")
  followings FollowRelation[] @relation("userFollowing")

  posts Posts[]
  comments Comments[]

  postLikes PostLikes[]
  commentLikes CommentLikes[]
}

model Profile {
  id Int @id @default(autoincrement()) 
  userID Int
  pfp String?
  header String?
  bio String?

  user User @relation(fields: [userID], references: [id])
}

model Inventory {
  id Int @id @default(autoincrement())
  belongsTo Int

  brandName String
  productName String
  productCategory Category
  price Int

  status Status @default(noStatus)

  backup Boolean @default(false)

  dateAquired String?
  rating Int?
  notes String?
  wouldBuyAgain RepurchaseChoice @default(null)

  whoseInventory User @relation(fields: [belongsTo], references: [id])
}

enum Category {
  skincare
  cosmetics
}

enum Status {
  noStatus
  inProgress
  limbo
}

enum RepurchaseChoice {
  null
  no
  yes
  maybe
  ifItWasGifted
}

model Decluttered {
  id Int @id @default(autoincrement())
  belongsTo Int
  brandName String
  productName String
  productCategory String



  whosDecluttered User @relation(fields: [belongsTo], references: [id])

}

model FullPan {
  id Int @id @default(autoincrement())
  belongsTo Int
  brandName String
  productName String
  productCategory String


  whoFullPanned User @relation(fields: [belongsTo], references: [id])

}

model FollowRelation {
  id Int @id @default(autoincrement())

  follower Int
  following Int

  followers User @relation("userFollowers", fields: [follower], references: [id])
  followings User @relation("userFollowing", fields: [following], references: [id])

  @@unique([follower, following])

}

model Posts {
  id Int @id @default(autoincrement())
  madeBy Int

  img String?
  title String
  body String
  timestamp DateTime @default(now())

  likes PostLikes[]
  comments Comments[]

  madeby User @relation(fields: [madeBy], references: [id])
}

model PostLikes {
  id Int @id @default(autoincrement())
  idOfPost Int
  userWhoLiked Int

  post Posts @relation(fields: [idOfPost], references: [id])
  liker User @relation(fields: [userWhoLiked], references: [id])

  @@unique([idOfPost, userWhoLiked])
}


model Comments {
  id Int @id @default(autoincrement())
  idOfPost Int
  userWhoCommented Int 

  body String
  timestamp DateTime @default(now())

  likes CommentLikes[]

  post Posts @relation(fields: [idOfPost], references: [id])
  commenter User @relation(fields: [userWhoCommented], references: [id])

}

model CommentLikes {
  id Int @id @default(autoincrement())
  idOfComment Int
  userWhoLiked Int

  comments Comments @relation(fields: [idOfComment], references: [id])
  liker User @relation(fields: [userWhoLiked], references: [id])

  @@unique([idOfComment, userWhoLiked])
}