generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String

  profile Profile?
  
  inventory Inventory[]

  followers FollowRelation[] @relation("userFollowers")
  followings FollowRelation[] @relation("userFollowing")

  posts Posts[]
  comments Comments[]

  postsThisUserLikes PostLikes[]
  commentLikesByThisUser CommentLikes[]
}

model Profile {
  id Int @id @default(autoincrement()) 
  userID Int @unique
  pfp String @default("default-icon.png")
  header String?
  bio String?

  user User @relation(fields: [userID], references: [id], onDelete: Cascade)
}

model Inventory {
  id Int @id @default(autoincrement())
  belongsTo Int

  brand String
  product String
  category Category
  price Decimal
  img String

  status Status @default(noStatus)

  backup Boolean @default(false)

  purchaseDate String?
  rating Int?
  notes String?
  wouldBuyAgain RepurchaseChoice @default(null)

  whoseInventory User @relation(fields: [belongsTo], references: [id], onDelete: Cascade)
}

enum Category {
  skincare
  cosmetics
}

enum Status {
  noStatus
  inProgress
  limbo
  decluttered
  fullpan
}

enum RepurchaseChoice {
  null
  no
  yes
  maybe
  ifItWasGifted
  
}


model FollowRelation {
  id Int @id @default(autoincrement())

  follower Int
  following Int

  followerAcc User @relation("userFollowers", fields: [follower], references: [id], onDelete: Cascade)
  followingAcc User @relation("userFollowing", fields: [following], references: [id], onDelete: Cascade)

  @@unique([follower, following])

}

model Posts {
  id Int @id @default(autoincrement())
  madeBy Int

  title String
  body String
  img String[]
  timestamp DateTime @default(now())

  likes PostLikes[]
  comments Comments[]

  madeby User @relation(fields: [madeBy], references: [id], onDelete: Cascade)
}

model PostLikes {
  id Int @id @default(autoincrement())
  idOfPost Int
  userWhoLiked Int

  post Posts @relation(fields: [idOfPost], references: [id])
  liker User @relation(fields: [userWhoLiked], references: [id], onDelete: Cascade)

  @@unique([idOfPost, userWhoLiked])
}


model Comments {
  id Int @id @default(autoincrement())
  idOfPost Int
  userWhoCommented Int 

  body String
  timestamp DateTime @default(now())

  likes CommentLikes[]

  post Posts @relation(fields: [idOfPost], references: [id])
  commenter User @relation(fields: [userWhoCommented], references: [id], onDelete: Cascade)

}

model CommentLikes {
  id Int @id @default(autoincrement())
  idOfComment Int
  userWhoLiked Int

  comments Comments @relation(fields: [idOfComment], references: [id])
  liker User @relation(fields: [userWhoLiked], references: [id], onDelete: Cascade)

  @@unique([idOfComment, userWhoLiked])
}