generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  name String
  username String @unique
  email String @unique
  saltedHash String
  
  inventory Inventory[]
  decluttered Decluttered []
  fullPan FullPan[]

  followers FollowRelation[] @relation("userFollowers")
  followings FollowRelation[] @relation("userFollowing")
}

model Inventory {
  id Int @id @default(autoincrement())
  belongsTo Int

  brandName String
  productName String
  productCategory String
  price Int

  status Status @default(noStatus)

  archieved Boolean @default(false)

  dateAquired String?
  rating Int?
  notes String?
  wouldBuyAgain RepurchaseChoice

  whoseInventory User @relation(fields: [belongsTo], references: [id])
}

enum Status {
  noStatus
  inProgress
  limbo
}

enum RepurchaseChoice {
  no
  yes
  maybe
  ifItWasGifted
}

model Decluttered {
  id Int @id @default(autoincrement())
  belongsTo Int
  brandName String
  productName String
  productCategory String



  whosDecluttered User @relation(fields: [belongsTo], references: [id])

}

model FullPan {
  id Int @id @default(autoincrement())
  belongsTo Int
  brandName String
  productName String
  productCategory String


  whoFullPanned User @relation(fields: [belongsTo], references: [id])

}

model FollowRelation {
  id Int @id @default(autoincrement())

  follower Int
  following Int

  followers User @relation("userFollowers", fields: [follower], references: [id])
  followings User @relation("userFollowing", fields: [following], references: [id])

  @@unique([follower, following])


}
